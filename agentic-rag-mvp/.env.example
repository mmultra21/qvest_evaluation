# Example environment variables for the Agentic RAG MVP
# Copy to ".env" and edit values for your local dev environment.

# Librarian credentials used by the demo auth layer
LIBRARIAN_USER=librarian
LIBRARIAN_PASS=supersecret

# Optional: LLM endpoint
# LLM_URL=http://127.0.0.1:11434

# Other env vars (examples):
# SENTRY_DSN=...
# DATABASE_URL=postgresql://user:pass@localhost/db
